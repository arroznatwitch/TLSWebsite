{
  "name": "tlswebsite",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "source": "index.html",
  "scripts": {
    "predev": "node -e \"const fs=require('fs');fs.mkdirSync('dist',{recursive:true});fs.cpSync('public','dist',{recursive:true})\"",
    "dev": "parcel index.html --port 1234",
    "build": "node build.js",
    "clean": "node -e \"const fs=require('fs');['.parcel-cache','dist'].forEach(p=>fs.rmSync(p,{recursive:true,force:true}))\"",
    "lint": "eslint ."
  },
  "staticFiles": {
    "staticPath": "public"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "eslint": "^9.13.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.11.0",
    "parcel": "^2.12.0",
    "parcel-reporter-static-files-copy": "^1.5.3",
    "process": "^0.11.10"
  }
}
